{
    "app_config": {
        "audio_config": {
            "audio": "pipewire"
        },
        "firewall_config": {
            "firewall": "ufw"
        },
        "fonts_config": {
            "fonts": [
                "noto-fonts"
            ]
        }
    },
    "archinstall-language": "English",
    "auth_config": {},
    "bootloader_config": {
        "bootloader": "Limine",
        "removable": false,
        "uki": false
    },
    "custom_commands": [],
    "hostname": "archlinux",
    "kernels": [
        "linux",
        "linux-lts"
    ],
    "locale_config": {
        "kb_layout": "us",
        "sys_enc": "UTF-8",
        "sys_lang": "en_US.UTF-8"
    },
    "mirror_config": {
        "custom_repositories": [],
        "custom_servers": [],
        "mirror_regions": {
            "Worldwide": [
                "http://mirror.rackspace.com/archlinux/$repo/os/$arch",
                "https://mirror.rackspace.com/archlinux/$repo/os/$arch",
                "https://ftpmirror.infania.net/mirror/archlinux/$repo/os/$arch",
                "https://geo.mirror.pkgbuild.com/$repo/os/$arch",
                "https://fastly.mirror.pkgbuild.com/$repo/os/$arch"
            ]
        },
        "optional_repositories": [
            "multilib"
        ]
    },
    "network_config": {
        "type": "nm"
    },
    "ntp": true,
    "packages": [
        "alacritty",
        "konsole",
        "fish",
        "git",
        "base-devel",
        "firefox",
        "micro",
        "snap-pac"
    ],
    "pacman_config": {
        "color": true,
        "parallel_downloads": 5
    },
    "profile_config": {
        "gfx_driver": "AMD / ATI (open-source)",
        "greeter": "plasma-login-manager",
        "profile": {
            "custom_settings": {
                "KDE Plasma": {
                    "plasma_flavor": "plasma-meta"
                }
            },
            "details": [
                "KDE Plasma"
            ],
            "main": "Desktop"
        }
    },
    "script": null,
    "services": [],
    "swap": {
        "algorithm": "zstd",
        "enabled": true
    },
    "timezone": "America/Boise",
    "version": "4.3"
}
